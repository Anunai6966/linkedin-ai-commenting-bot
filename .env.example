# Environment Variables
# Copy this file, rename to .env, and fill in your actual values
# Never commit your actual .env file to GitHub

# Unipile
UNIPILE_API_KEY=your_unipile_api_key_here
UNIPILE_ACCOUNT_ID=your_unipile_account_id_here
UNIPILE_DSN=your_unipile_dsn_here  # e.g. api4.unipile.com:13474

# Airtable (configured via n8n OAuth credential)
AIRTABLE_BASE_ID=your_airtable_base_id_here

# Apify (configured via n8n OAuth credential)
# API key managed inside n8n credentials

# Google Gemini (configured via n8n credential)
# API key managed inside n8n credentials
